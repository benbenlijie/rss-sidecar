# RSS Sidecar configuration via environment variables
# Copy to .env and fill in values

# Translation provider
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Alternative providers (uncomment to use):
# DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# Ollama (local, zero cost)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:7b

# FreshRSS integration (optional - leave empty for standalone mode)
FRESHRSS_URL=http://freshrss:80
FRESHRSS_USERNAME=admin
FRESHRSS_API_PASSWORD=

# Cost control
DAILY_BUDGET_USD=1.00
MAX_ARTICLES_PER_DAY=100
MAX_RETRIES=2

# Server
HOST=0.0.0.0
PORT=8000
