# RSS Sidecar configuration
# Copy this file to .env and fill in your own values

# ============================================================
# Translation Provider (required)
# Any OpenAI-compatible API works. Pick one and configure.
# ============================================================

OPENAI_API_KEY=

# --- OpenAI ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- GLM (Zhipu AI) ---
# OPENAI_BASE_URL=https://api.z.ai/api/paas/v4
# OPENAI_MODEL=glm-4-flash

# --- DeepSeek ---
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- Ollama (local, zero API cost) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:7b
# OPENAI_API_KEY=ollama

# --- Any other OpenAI-compatible provider ---
# OPENAI_BASE_URL=https://your-provider.com/v1
# OPENAI_MODEL=your-model

# ============================================================
# Translation pricing (optional, for cost tracking)
# Per 1 million tokens in USD. If unset, uses built-in defaults
# for known models, otherwise estimates conservatively.
# ============================================================
# TRANSLATION_INPUT_PRICE=0.15
# TRANSLATION_OUTPUT_PRICE=0.60

# ============================================================
# Embedding (optional, for semantic similarity)
# Any OpenAI-compatible embedding API. Enables "similar articles"
# discovery beyond knowledge graph entity matching.
# ============================================================
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# RSS Backend (optional)
# Choose one: FreshRSS or Miniflux. Leave empty for standalone mode.
# ============================================================

# --- FreshRSS ---
FRESHRSS_URL=
FRESHRSS_USERNAME=
FRESHRSS_API_PASSWORD=

# --- Miniflux ---
MINIFLUX_URL=
MINIFLUX_API_KEY=

# ============================================================
# Cost control
# ============================================================
DAILY_BUDGET_USD=1.00
MAX_ARTICLES_PER_DAY=100
MAX_RETRIES=2

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000

# ============================================================
# Translation target language
# Examples: zh-CN, ja, ko, en, fr, de, es
# ============================================================
TARGET_LANGUAGE=zh-CN
